# Build output
/dist/

# Vendored whisper.cpp source + build (cloned/built by `make whisper`)
/third_party/

# Downloaded model (pulled by `make model`, lives in ~/Library/Application Support)
/models/

# Generated icon artifacts (regenerated by `make icon`); the source is logo-source.svg
/build/icon.icns
/build/icon-master.png
/build/icon.iconset/

# Local Claude Code settings (per-machine permissions)
/.claude/settings.local.json

# macOS
.DS_Store
